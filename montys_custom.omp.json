{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#bdb2ff",
          "style": "plain",
          "template": "\u256d\u2500\ue0b6",
          "type": "text"
        },
        {
          "background": "#bdb2ff",
          "foreground": "#011627",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "properties": {
            "windows": "\uF303"
          },
          "style": "powerline",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}  ",
          "type": "os"
        },
        {
          "background": "#84a59d",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "branch_icon": " \ue0a0 ",
            "fetch_status": false
          },
          "style": "powerline",
          "template": " ({{ .HEAD }}) ",
          "type": "git"
        },
        {
          "background": "#84a59d",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \ue718 {{ .Full }} ",
          "type": "node"
        },
        {
          "background": "#bdb2ff",
          "foreground": "#ffffff",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "template": " \uf469 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#b5838d",
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "style": "folder"
          },
          "style": "diamond",
          "template": " \uf07b {{ .Path }} ",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#bdb2ff",
          "style": "plain",
          "template": "\u2570\u2500\ue285\ueab6 ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
